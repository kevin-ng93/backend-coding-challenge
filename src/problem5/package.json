{
  "name": "problem5-crud-api",
  "version": "1.0.0",
  "private": true,
  "description": "ExpressJS TypeScript CRUD API with SQLite persistence",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@jest/globals": "^30.4.1",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^7.0.0",
    "zod": "^4.0.17"
  },
  "overrides": {
    "tar-fs": "^2.1.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.4.5",
    "@types/supertest": "^2.0.12",
    "jest": "^29.6.2",
    "jest-mock": "^30.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
